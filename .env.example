BOT_TOKEN=8180772495:AAFnM8IBZjT1b9AUUAxP30zHtDVbF3eB7cY

# ru, en, or auto
DEFAULT_LANGUAGE=ru

# Free local speech-to-text. Use tiny for speed, base for balance, small for better quality.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_CHUNK_SECONDS=600

# Railway volume-friendly paths. Mount a volume to /data if you want cache/db to survive restarts.
WORK_DIR=/data/bot-transcriber
DB_PATH=/data/bot-transcriber/bot.sqlite3
HF_HOME=/data/huggingface

# Keep this default for small files. For >20 MB use a local Telegram Bot API server.
TELEGRAM_API_BASE=https://api.telegram.org

# Keep one job on small Railway instances.
MAX_CONCURRENT_JOBS=1
